# AI-Q Blueprint - Environment Configuration
#
# Copy to .env and set your values:
#   cp deploy/.env.example deploy/.env

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
AIQ_DEV_ENV=cli

# -----------------------------------------------------------------------------
# API Keys (required for core functionality)
# -----------------------------------------------------------------------------
NVIDIA_API_KEY=


#  Search Tools (Required)
TAVILY_API_KEY=
SERPER_API_KEY=
YOU_API_KEY=


